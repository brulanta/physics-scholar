```bash
# ─────────────────────────────────────────────
# PhysicsScholar 开发环境配置
# 复制本文件为 .env 并填入实际值
# 优先级高于 config/user_config.yaml
# ─────────────────────────────────────────────

# ── 主 LLM（必填）────────────────────────────
MAIN_API_KEY=
MAIN_BASE_URL=https://api.deepseek.com
MAIN_MODEL=deepseek-chat

# ── 副 LLM（选填，留空则复用主 LLM）──────────
SUB_API_KEY=
SUB_BASE_URL=
SUB_MODEL=

# ── Embedding（必填）─────────────────────────
# 推荐使用硅基流动免费模型：https://siliconflow.cn
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# ── 第三方工具（选填）────────────────────────
JINA_API_KEY=
S2_API_KEY=
OPENALEX_EMAIL=
```