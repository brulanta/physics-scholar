        "dim_b": "",
        "paperId": "8039dd37436ff5b86fc96b921cba89228002ff0e",
        "citationCount": 133,
        "externalIds": {
            "DOI": "10.1364/ol.28.001415"
        }
    },
    {
        "doi": "10.1103/physrev.152.705",
        "s2_id": "4d5f3b06fe57c29c7ba9c1cc3777e2532fbc5cb7",
        "title": "Raman Scattering by Lithium Niobate",
        "authors": "R. F. Schaufele, M. Weber",
        "year": 1966,
        "venue": "",
        "citation_count": 132,
        "abstract": "Polarized Raman scattering from a crystal of LiNb${\\mathrm{O}}_{3}$ has been measured at room temperature using a continuous He-Ne gas laser as a source. The spectra and scattering efficiencies are discussed and frequency assignments are made for three transverse ${A}_{1}$ and one longitudinal and seven transverse $E$ vibrations.",
        "pdf_url": "",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
