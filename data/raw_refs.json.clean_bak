    {
        "doi": "10.1049/cp.2019.1027",
        "s2_id": "4354441809bce1311e44ba7becddda598ff46959",
        "title": "220 Gbit/s optical PAM4 modulation based on lithium niobate on insulator modulator",
        "authors": "Z. Yuguang, Mengyue Xu, Hongguang Zhang et al.",
        "year": 2019,
        "venue": "",
        "citation_count": 19,
        "abstract": "We experimentally demonstrate ultra-high speed optical modulations up to 120 Gbit/s (120 Gbaud NRZ) and 220 Gbit/s (110 Gbaud PAM4) based on a lithium niobate on insulator (LNOI) modulator, which has a 3-dB electro-optical bandwidth of 56 GHz and the Vπ of 2.6 V.",
        "pdf_url": "",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
