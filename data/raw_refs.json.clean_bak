        }
    },
    {
        "doi": "10.1038/nature22986",
        "s2_id": "29cb0cddef897ef6de00408e7c5b161347069a8d",
        "title": "On-chip generation of high-dimensional entangled quantum states and their coherent control",
        "authors": "M. Kues, C. Reimer, P. Roztocki et al.",
        "year": 2017,
        "venue": "Nature",
        "citation_count": 945,
        "abstract": "",
        "pdf_url": "",
