    {
        "doi": "10.1364/optica.5.001396",
        "s2_id": "315b572234c75db31ba599e8adc2e683fe595793",
        "title": "Synthetic dimension in photonics",
        "authors": "Luqi Yuan, Qian Lin, Meng Xiao et al.",
        "year": 2018,
        "venue": "Optica",
        "citation_count": 344,
        "abstract": "The physics of a photonic structure is commonly described in terms of its apparent geometric dimensionality. On the other hand, with the concept of synthetic dimension, it is in fact possible to explore physics in a space with a dimensionality that is higher as compared to the apparent geometrical dimensionality of the structures. In this review, we discuss the basic concepts of synthetic dimension in photonics, and highlighting the various approaches towards demonstrating such synthetic dimension for fundamental physics and potential applications.",
        "pdf_url": "https://doi.org/10.1364/optica.5.001396",
        "pub_types": [
            "Review"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
