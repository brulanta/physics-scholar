        }
    },
    {
        "doi": "10.1364/josab.21.000376",
        "s2_id": "092bbc4d4ec18b914545df92d32e030b948dcb6a",
        "title": "Controllable Raman-like nonlinearities from nonstationary, cascaded quadratic processes",
        "authors": "F. Ilday, K. Beckwitt, Y. Chen et al.",
        "year": 2003,
        "venue": "",
        "citation_count": 58,
        "abstract": "We show that useful noninstantaneous, nonlinear phase shifts can be obtained from cascaded quadratic processes in the presence of group-velocity mismatch. The two-field nature of the process permits responses that can be effectively advanced or retarded in time with respect to one of the fields. There is an analogy to a generalized Raman-scattering effect, permitting both red and blueshifts of short pulses. We expect this capability to have many applications in short-pulse generation and propagation, such as the compensation of Raman-induced effects and high-quality pulse compression, which we discuss.",
        "pdf_url": "https://arxiv.org/pdf/physics/0310036",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
