    {
        "doi": "10.1063/5.0012288",
        "s2_id": "07462b6874a860b97644f35c70af7c46b4c4fc2b",
        "title": "Acousto-optic modulation in lithium niobate on sapphire",
        "authors": "Christopher J. Sarabalis, T. McKenna, Rishi N. Patel et al.",
        "year": 2020,
        "venue": "APL Photonics",
        "citation_count": 66,
        "abstract": "We demonstrate acousto-optic phase modulators in X-cut lithium niobate films on sapphire, detailing the dependence of the piezoelectric and optomechanical coupling coefficients on the crystal orientation. This new platform supports highly confined, strongly piezoelectric mechanical waves without suspensions, making it a promising candidate for broadband and efficient integrated acousto-optic devices, circuits, and systems.",
        "pdf_url": "https://aip.scitation.org/doi/pdf/10.1063/5.0012288",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
