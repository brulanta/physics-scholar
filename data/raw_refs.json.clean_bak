    {
        "doi": "10.1117/12.894515",
        "s2_id": "c0bbb7bfb21510e7e9a3080771b00cd0662b9812",
        "title": "On-chip stimulated Brillouin scattering",
        "authors": "R. Pant, C. Poulton, D. Choi et al.",
        "year": 2010,
        "venue": "Australian Conference on Optical Fibre Technology",
        "citation_count": 306,
        "abstract": "We report the first demonstration of on-chip stimulated Brillouin scattering (SBS) with low average power. The measured Brillouin shift and line width are ~7.7 GHz and ~6 MHz in a 7 cm long chalcogenide waveguide.",
