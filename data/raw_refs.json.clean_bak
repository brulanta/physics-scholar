        "citationCount": 367,
        "externalIds": {
            "DOI": "10.1109/jlt.2009.2031423"
        }
    },
    {
        "doi": "10.1016/j.jlumin.2010.12.015",
        "s2_id": "5e02049d772d88b85adafd370bd51be9e51982d1",
        "title": "Rare-earth-doped materials for applications in quantum information storage and signal processing",
        "authors": "C. Thiel, T. Böttger, R. Cone",
        "year": 2011,
        "venue": "",
        "citation_count": 368,
        "abstract": "",
        "pdf_url": "",
        "pub_types": [
            "Review"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
