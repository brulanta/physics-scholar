            "DOI": "10.1002/que2.9"
        }
    },
    {
        "doi": "10.1364/ol.44.001222",
        "s2_id": "cddf7e224643985416f2f232ef1097f8730882a0",
        "title": "Coherent Two-Octave-Spanning Supercontinuum Generation in Lithium-Niobate Waveguides",
        "authors": "Mengjie Yu, B. Desiatov, Yoshitomo Okawachi et al.",
        "year": 2019,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 127,
        "abstract": "We demonstrate a coherent supercontinuum spanning two octaves with 35 pJ pulses in a lithium-niobate waveguide under the presence of second-and third-order nonlinear effects, which allows for detection of the carrier-envelope offset frequency on-chip. © 2019 The Author(s)",
        "pdf_url": "https://doi.org/10.1364/ol.44.001222",
        "pub_types": [
            "JournalArticle",
            "Conference"
        ],
        "source_reviews": [
