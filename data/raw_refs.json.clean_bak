    {
        "doi": "10.1364/oe.19.015833",
        "s2_id": "50cdf997ae9879510338a897a1aa264ac6c1d61f",
        "title": "A design method of lithium niobate on insulator ridge waveguides without leakage loss.",
        "authors": "E. Saitoh, Y. Kawaguchi, K. Saitoh et al.",
        "year": 2011,
        "venue": "Optics Express",
        "citation_count": 16,
        "abstract": "We evaluate structural dependency of leakage losses in lithium niobate on insulator ridge waveguides. Generally, shallow ridge waveguides based on isotropic materials have inherent leakage loss for TM-like mode. On the other hand, lithium niobate is anisotropic material, thus the optical properties of lithium niobate based ridge waveguides are different from those of isotopic material based ridge waveguides. In this paper, we investigate leakage losses of lithium niobate on insulator ridge waveguides. We show that the shallow ridge waveguide structure without leakage loss can be realized by choosing the waveguide parameters adequately.",
        "pdf_url": "https://doi.org/10.1364/oe.19.015833",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
        "paperId": "50cdf997ae9879510338a897a1aa264ac6c1d61f",
        "citationCount": 16,
        "externalIds": {
            "DOI": "10.1364/oe.19.015833"
        }
    },
    {
        "doi": "10.1143/jjap.45.8696",
        "s2_id": "8961bba8cd604e068f271530c30b1465c1670637",
        "title": "Velocity-Matching Conditions for Ultrahigh-Speed Optical LiNbO3 Modulators with Traveling-Wave Electrode",
        "authors": "K. Aoki, Jungo Kondou, O. Mitomi et al.",
        "year": 2006,
        "venue": "",
        "citation_count": 16,
        "abstract": "In traveling-wave-type optical modulators, the microwave effective index should match the optical group index to realize a maximum bandwidth and a minimum driving voltage. Considering the material dispersion of LiNbO 3 (LN) and the waveguide dispersion of a Ti-diffused optical waveguide, we obtained a waveguide group index of 2.189 at a wavelength of 1550 nm, which is 0.051 larger than the waveguide phase index, from both calculation and experimental results. The effect of the waveguide dispersion on the group index was also found to be much smaller than that of the material dispersion of LN. It was demonstrated experimentally that the index difference induced by index dispersion strongly affects the frequency responses of ultrafast and ultralow-driving-voltage LN modulators.",
        "pdf_url": "",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
        "paperId": "8961bba8cd604e068f271530c30b1465c1670637",
        "citationCount": 16,
        "externalIds": {
            "DOI": "10.1143/jjap.45.8696"
        }
    },
    {
        "doi": "10.1109/jlt.2019.2945017",
        "s2_id": "77a631a5aaa06a3cd4a0321f0afb93b4927c5e9f",
        "title": "Demonstration of Multivariate Photonics: Blind Dimensionality Reduction With Integrated Photonics",
        "authors": "A. Tait, Philip Y. Ma, T. Ferreira de Lima et al.",
        "year": 2019,
        "venue": "Journal of Lightwave Technology",
        "citation_count": 16,
        "abstract": "Multi-antenna radio front-ends generate a multi-dimensional flood of information, most of which is partially redundant. Redundancy is eliminated by dimensionality reduction. This class of operations presents harsh fundamental tradeoffs to contemporary digital processing techniques. These tradeoffs can be broken in the analog domain, in which the performance of optical technologies greatly exceeds that of electronic counterparts. Here, we present concepts, methods, and a first demonstration of multivariate photonics: a combination of integrated photonic hardware, analog dimensionality reduction, and blind algorithmic techniques. We experimentally demonstrate 2-channel, 1.0 GHz principal component analysis in a photonic weight bank using recently proposed algorithms for synthesizing the multivariate properties of signals to which the receiver is blind. Novel methods are introduced for controlling blindness conditions in a laboratory context. This work provides a foundation for further research in multivariate photonic information processing, which is poised to play a role in future generations of wireless technology.",
        "pdf_url": "https://doi.org/10.1109/jlt.2019.2945017",
        "pub_types": [],
        "source_reviews": [
            "10.1038/s41566-020-00754-y"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
        "paperId": "77a631a5aaa06a3cd4a0321f0afb93b4927c5e9f",
        "citationCount": 16,
        "externalIds": {
            "DOI": "10.1109/jlt.2019.2945017"
        }
    },
    {
        "doi": "10.1109/lpt.2010.2069558",
        "s2_id": "a5f37f92ad6a5ed139000b7b7adc9156039b9cc0",
        "title": "True Time Delay Photonic Circuit Based on Perfluorpolymer Waveguides",
        "authors": "A. Yeniay, R. Gao",
        "year": 2010,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 15,
        "abstract": "A high-performance 4-bit optical true time delay device is realized on a perfluoropolymer integrated optic platform. The integrated waveguide circuit is based on athermal arrayed wavegide grating with monolithically integrated delay lines in a wavelength-selective recirculating loop configuration. The device provides precise delay length control (i.e., 1 m) over 16 channels with 40-ps incremental time delays. The device offers athermal operation over the 0°C-50°C range with a maximum insertion loss of 6.8 dB and a polarization shift of 0.4 nm. This compact device (20 × 32 × 3 mm <sup xmlns:mml=\"http://www.w3.org/1998/Math/MathML\" xmlns:xlink=\"http://www.w3.org/1999/xlink\">3</sup> ) promises applications in code-division multiple access and phased arrayed antenna systems, where the large channel counts with high resolution delay length controls and small footprints are required.",
        "pdf_url": "",
        "pub_types": [],
        "source_reviews": [
            "10.1002/lpor.201200032"
        ],
        "directions": [],
        "dim_a": "",
