    {
        "doi": "10.1364/optica.6.001342",
        "s2_id": "922229ddfdaac91c20cefc21c1ab4fccd8e65400",
        "title": "Photonic Integrated Circuits with Bound States in the Continuum",
        "authors": "Zejie Yu, Xiang Xi, Jingwen Ma et al.",
        "year": 2019,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 130,
        "abstract": "We experimentally demonstrated photonic integrated circuits with bound states in the continuum by patterning low-refractive-index waveguides on a high-refractive-index substrate. We also demonstrated high-Q microcavities, directional couplers, and electro-optic modulators working under this principle.",
        "pdf_url": "https://doi.org/10.1364/optica.6.001342",
