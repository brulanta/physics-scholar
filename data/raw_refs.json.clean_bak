    {
        "doi": "10.1103/physrevlett.92.043903",
        "s2_id": "7e2a25c185bf179f9f9705a45fd9b7330d7ee380",
        "title": "Nonlinear optics and crystalline whispering gallery mode cavities.",
        "authors": "V. Ilchenko, A. Savchenkov, A. Matsko et al.",
        "year": 2004,
        "venue": "Physical Review Letters",
        "citation_count": 421,
        "abstract": "We demonstrate parametric frequency doubling in a whispering gallery cavity made of periodically poled lithium niobate. This demonstration is an example of utility of such crystalline optical whispering gallery resonators with very high Q factors, which we have fabricated.",
        "pdf_url": "",
