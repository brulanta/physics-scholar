    {
        "doi": "10.1364/ol.37.001721",
        "s2_id": "116f446a7b559a9efaa007cd47cc152fe554e888",
        "title": "Silicon slow-light-based photonic mixer for microwave-frequency conversion applications.",
        "authors": "A. Gutiérrez, A. Brimont, J. Herrera et al.",
        "year": 2012,
        "venue": "Optics Letters",
        "citation_count": 6,
        "abstract": "We describe and demonstrate experimentally a method for photonic mixing of microwave signals by using a silicon electro-optical Mach-Zehnder modulator enhanced via slow-light propagation. Slow light with a group index of ~11, achieved in a one-dimensional periodic structure, is exploited to improve the upconversion performance of an input frequency signal from 1 to 10.25 GHz. A minimum transmission point is used to successfully demonstrate the upconversion with very low conversion losses of ~7 dB and excellent quality of the received I/Q modulated QPSK signal with an optimum EVM of ~8%.",
        "pdf_url": "https://riunet.upv.es/bitstream/10251/30871/1/OPTLETTERS_AGutierrez.pdf",
        "pub_types": [
