        }
    },
    {
        "doi": "10.1109/lpt.2011.2163184",
        "s2_id": "e5be0370ac8fc78bc87f1ccd18823113c1bc0419",
        "title": "A Monolithically Integrated ACP-OPLL Receiver for RF/Photonic Links",
        "authors": "Yifei Li, A. Bhardwaj, Renyuan Wang et al.",
        "year": 2011,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 24,
        "abstract": "The first monolithically integrated optical phase-locked loop (OPLL) employing attenuating-counter-propagating waves is presented. It demonstrates the highest dynamic range among monolithically integrated OPLLs. Its performance is limited by the bandwidth and linearity of the photodetectors used in the OPLL.",
