    {
        "paperId": "cc5ac72bd7934e7e7b735bf9c999a311b149273d",
        "title": "Microwave photonics",
        "venue": "",
        "year": 2002,
        "citationCount": 68,
        "s2_id": "cc5ac72bd7934e7e7b735bf9c999a311b149273d",
        "citation_count": 68,
        "doi": "10.1109/22.989971",
        "abstract": "Microwave photonics is the use of photonic techniques for the generation, transmission, processing and reception of signals having spectral components at microwave frequencies. This tutorial reviews the technologies used and gives applications examples.",
        "authors": "A. Seeds",
        "externalIds": {
            "DOI": "10.1109/22.989971"
