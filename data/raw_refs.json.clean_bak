    {
        "doi": "10.1109/lpt.2008.2009468",
        "s2_id": "848e6771dd10c67c1b14c58c512c770de9383abe",
        "title": "Widely Tunable Microwave Photonic Notch Filter Based on Slow and Fast Light Effects",
        "authors": "W. Xue, S. Sales, J. Mørk et al.",
        "year": 2009,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 77,
        "abstract": "A continuously tunable microwave photonic notch filter at around 30 GHz is experimentally demonstrated and 100% fractional tuning over 360deg range is achieved without changing the shape of the spectral response. The tuning mechanism is based on the use of slow and fast light effects in semiconductor optical amplifiers assisted by optical filtering.",
        "pdf_url": "https://backend.orbit.dtu.dk/ws/files/6411057/Xue.pdf",
        "pub_types": [],
        "source_reviews": [
            "10.1002/lpor.201200032"
        ],
        "directions": [],
        "dim_a": "",
