        "citationCount": 71,
        "externalIds": {
            "DOI": "10.1364/oe.397138"
        }
    },
    {
        "doi": "10.1364/ol.42.003267",
        "s2_id": "c100dd61e419b5cf38c0d76a7d6d2f0671f26e07",
        "title": "Fast response of photorefraction in lithium niobate microresonators.",
        "authors": "Haowei Jiang, Rui Luo, Hanxiao Liang et al.",
        "year": 2017,
        "venue": "Optics Letters",
        "citation_count": 71,
        "abstract": "We present a detailed characterization of photorefraction in on-chip high-Q lithium niobate (LN) microresonators. We show that the photorefractive effect in these devices exhibits very distinctive temporal relaxation dynamics compared with those in bulk crystals and in mm-sized LN resonators. The relaxation of photorefraction is dominated by a fast time response with a time constant as small as 20.85 ms that is more than three-orders of magnitude faster than those observed in macroscopic devices. The observed fast response of photorefraction is of great potential as a convenient and energy-efficient approach for on-chip all-optical functionalities.",
        "pdf_url": "https://doi.org/10.1364/ol.42.003267",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
