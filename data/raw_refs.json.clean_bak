    {
        "doi": "10.1364/ol.38.000151",
        "s2_id": "b719a6acc1b2df457e48039208f36110469577e4",
        "title": "Generalized dispersive wave emission in nonlinear fiber optics.",
        "authors": "K. Webb, Yiqing Xu, M. Erkintalo et al.",
        "year": 2013,
        "venue": "Optics Letters",
        "citation_count": 75,
        "abstract": "We show that the emission of dispersive waves in nonlinear fiber optics is not limited to soliton-like pulses propagating in the anomalous dispersion regime. We demonstrate, both numerically and experimentally, that pulses propagating in the normal dispersion regime can excite resonant dispersive radiation across the zero-dispersion wavelength into the anomalous regime.",
        "pdf_url": "",
