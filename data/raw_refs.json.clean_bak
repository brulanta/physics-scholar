        "s2_id": "e4a01ef8a9ca9a50bba4a0d7604d27762fe08a02",
        "title": "Seeking symmetry",
        "authors": "Yoshitomo Okawachi, A. Gaeta",
        "year": 2012,
        "venue": "Nature Photonics",
