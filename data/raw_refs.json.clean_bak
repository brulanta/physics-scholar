        "citationCount": 68,
        "externalIds": {
            "DOI": "10.1364/oe.27.035659"
        }
    },
    {
        "doi": "10.1364/ol.41.002719",
        "s2_id": "6e2cfd4703df5b9035a61d874d72bc83512841ec",
        "title": "Octave-spanning supercontinuum generation in a silicon-rich nitride waveguide",
        "authors": "Xing Liu, Binbin Zhou, M. Bache et al.",
        "year": 2016,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 68,
        "abstract": "We generate supercontinuum (817-2250 nm at -30dB) in a dispersion-engineered silicon-rich nitride waveguide by pumping fs pulses with 82 pJ from an erbium-fiber oscillator. Spectral broadening mechanisms include soliton fission and dispersive wave generation.",
        "pdf_url": "http://publications.lib.chalmers.se/records/fulltext/238177/local_238177.pdf",
