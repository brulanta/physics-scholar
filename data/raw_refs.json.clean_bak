        }
    },
    {
        "doi": "10.1103/physrevlett.15.964",
        "s2_id": "1dc1d41d9fd0d84501873224224797b5488f5382",
        "title": "Raman Scattering by Polaritons",
        "authors": "C. Henry, J. Hopfield",
        "year": 1965,
        "venue": "",
        "citation_count": 237,
        "abstract": "Received 12 October 1965DOI:https://doi.org/10.1103/PhysRevLett.15.964©1965 American Physical Society",
