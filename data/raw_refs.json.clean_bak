    {
        "doi": "10.1109/lpt.2002.1021994",
        "s2_id": "c1251472f6b99d5474a2333f25098b7754a6d1dc",
        "title": "Ring-assisted frequency discriminator with improved linearity",
        "authors": "Xiaobo Xie, J. Khurgin, Jin Kang et al.",
        "year": 2002,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 30,
        "abstract": "A frequency discriminator combining a Mach-Zehnder interferometer with ring resonators is proposed, analyzed and shown to offer a large improvement in linearity without any significant reduction in bandwidth. This can improve the performance of analog optical links by canceling the intermodulation distortion.",
        "pdf_url": "",
