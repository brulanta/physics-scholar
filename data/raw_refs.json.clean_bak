    {
        "doi": "10.1063/1.5118901",
        "s2_id": "831af28b6281da2b1b5688f44913bbdf0af26a33",
        "title": "Silicon photodetector for integrated lithium niobate photonics",
        "authors": "B. Desiatov, M. Lončar",
        "year": 2019,
        "venue": "Applied Physics Letters",
        "citation_count": 60,
        "abstract": "We demonstrate the integration of an amorphous silicon photodetector with a thin film lithium niobate photonic platform operating in the visible wavelength range. We present the details of the design, fabrication, integration, and experimental characterization of this metal-semiconductor-metal photodetector that features a responsivity of 22 mA/W to 37 mA/W over the wide optical bandwidth spanning in the 635 nm–850 nm wavelength range.We demonstrate the integration of an amorphous silicon photodetector with a thin film lithium niobate photonic platform operating in the visible wavelength range. We present the details of the design, fabrication, integration, and experimental characterization of this metal-semiconductor-metal photodetector that features a responsivity of 22 mA/W to 37 mA/W over the wide optical bandwidth spanning in the 635 nm–850 nm wavelength range.",
        "pdf_url": "https://aip.scitation.org/doi/10.1063/1.5118901",
        "pub_types": [],
