    {
        "doi": "10.1109/68.588168",
        "s2_id": "10993e388f159c116b75dafae09283992a09e16a",
        "title": "Compact silicon-based integrated optic time delays",
        "authors": "S. Yegnanarayanan, P. Trinh, F. Coppinger et al.",
        "year": 1997,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 50,
        "abstract": "We demonstrate a 3-b (eight-channel) guided-wave optical delay line network in the silicon-on-insulator (SOI) waveguide technology with an incremental time delay of 12.3 ps measured over 2-20-GHz frequency range. The high-refractive index (compared to silica) combined with tight optical confinement and low propagation loss in the SOI waveguide enables us to realize a compact time-delay network with fine resolution time delays necessary in a high-frequency phased-array antenna.",
        "pdf_url": "",
        "pub_types": [],
