        }
    },
    {
        "doi": "10.1364/optica.5.000864",
        "s2_id": "2e7c6ae337127c883cba8beae03a5cb2b79eb798",
        "title": "Training of Photonic Neural Networks through In Situ Backpropagation",
        "authors": "Tyler W. Hughes, M. Minkov, Yu Shi et al.",
        "year": 2018,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 433,
        "abstract": "We provide a protocol for training photonic neural networks based on adjoint methods. The gradient of the network with respect to its tunable degrees of freedom is computed by physically backpropagating an optical error signal. © 2019 The Author(s)",
