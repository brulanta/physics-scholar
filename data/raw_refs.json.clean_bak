    {
        "paperId": "a0416fd3559840fdcf6bc52356614c377c743202",
        "title": "NEUROMORPHIC PHOTONICS",
        "venue": "",
        "year": 2017,
        "citationCount": 216,
        "s2_id": "a0416fd3559840fdcf6bc52356614c377c743202",
        "citation_count": 216,
        "doi": "10.1201/9781315370590",
        "abstract": "This book sets out to build bridges between the domains of photonic device physics and neural networks, providing a comprehensive overview of the emerging field of \"neuromorphic photonics.\" It includes a thorough discussion of evolution of neuromorphic photonics from the advent of fiber-optic neurons to today’s state-of-the-art integrated laser neurons, which are a current focus of international research. Neuromorphic Photonics explores candidate interconnection architectures and devices for integrated neuromorphic networks, along with key functionality such as learning. It is written at a level accessible to graduate students, while also intending to serve as a comprehensive reference for experts in the field.",
        "authors": "M. Nahmias, B. Shastri, A. Tait, T. F. D. Lima, P. Prucnal",
        "externalIds": {
            "DOI": "10.1201/9781315370590"
        }
    },
