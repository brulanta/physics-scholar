        }
    },
    {
        "doi": "10.1364/oe.19.011780",
        "s2_id": "fb00ee2a1b6730255021f42d492816ff8053ce21",
        "title": "Electronically tunable silicon photonic delay lines.",
        "authors": "Saeed Khan, M. Baghban, S. Fathpour",
        "year": 2011,
        "venue": "Optics Express",
        "citation_count": 69,
        "abstract": "Electronically tunable optical true-time delay lines are proposed. The devices utilize the combination of apodised gratings and the free-carrier plasma effect to tune the enhanced delay of silicon waveguides at a fixed wavelength. Three variations of the proposed scheme are studied and compared. The compact and integrable devices can achieve tuning ranges as high as ~660 ps with a loss of < 2.2 dB when operated in the reflection mode of the gratings. A delay of ~40 ps with a loss of < 10 dB and an estimated operation bit rate of ~20 Gb/s can be achieved.",
        "pdf_url": "https://doi.org/10.1364/oe.19.011780",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1002/lpor.201200032"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
        "paperId": "fb00ee2a1b6730255021f42d492816ff8053ce21",
        "citationCount": 69,
        "externalIds": {
            "DOI": "10.1364/oe.19.011780"
        }
    },
    {
        "doi": "10.1109/lpt.2007.891591",
        "s2_id": "97c31d1f58191be3d06d1ce40fa8e7a8c97360bf",
        "title": "Noise Figure Reduction in Externally Modulated Analog Fiber-Optic Links",
        "authors": "Adil Karim, J. Devenport",
        "year": 2007,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 69,
        "abstract": "An octave-bandwidth microwave photonic link with a third-order limited spurious-free dynamic range of 121 dB in a 1-Hz bandwidth has been demonstrated. The link noise figure of 9 dB at a modulation frequency of 2 GHz was achieved by using a bias-shifted Mach-Zehnder modulator with an optical input power of 500 mW. This level of performance was realized without electronic or optical linearization",
        "pdf_url": "",
        "pub_types": [],
        "source_reviews": [
            "10.1002/lpor.201200032",
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
