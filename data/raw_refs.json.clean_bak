        }
    },
    {
        "doi": "10.1364/oe.27.038521",
        "s2_id": "a15f6910dfdf026abedaca9ffcfd6e3c8ea898af",
        "title": "Generation of broadband correlated photon-pairs in short thin-film lithium-niobate waveguides.",
        "authors": "B. Elkus, Kamal Abdelsalam, A. Rao et al.",
        "year": 2019,
        "venue": "Optics Express",
        "citation_count": 39,
        "abstract": "An efficient source of quantum-correlated photon-pairs that is integrable with existing silicon-electronics fabrication techniques is desirable for use in quantum photonic integrated circuits. Here we demonstrate signal-idler photon pairs with high coincidence-to-accidental count ratios of over 103 on a coarse wavelength-division-multiplexing grid that spans 140 nm by using a 300-μm-long poled region in a thin-film periodically-poled lithium-niobate ridge waveguide bonded to silicon. The pairs are generated via spontaneous parametric downconversion pumped by a continuous-wave tunable laser source. The small mode area of the waveguide allows for efficient interaction in a short length of the waveguide and, as a result, permits photon-pair generation over a broad range of signal-idler wavelengths.",
        "pdf_url": "https://doi.org/10.1364/oe.27.038521",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
