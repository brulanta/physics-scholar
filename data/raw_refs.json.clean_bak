        "citationCount": 39,
        "externalIds": {
            "DOI": "10.1364/oe.27.038521"
        }
    },
    {
        "doi": "10.1063/1.5131664",
        "s2_id": "19a6473c2f0f25a6fa0b5f2c32dbfbda8bf93d0b",
        "title": "Superconducting nanowire single-photon detectors fabricated from atomic-layer-deposited NbN",
        "authors": "Risheng Cheng, Sihao Wang, Hong X. Tang",
        "year": 2019,
        "venue": "Applied Physics Letters",
        "citation_count": 39,
        "abstract": "High-quality ultrathin films of niobium nitride (NbN) are developed by the plasma-enhanced atomic layer deposition (PEALD) technique. Superconducting nanowire single-photon detectors patterned from this material exhibit high switching currents and saturated internal efficiencies over a broad bias range at a telecommunication wavelength of 1550 nm. Statistical analyses on hundreds of fabricated devices show a near-unity throughput yield due to the exceptional homogeneity of the films. The ALD-NbN material represents an ideal superconducting material for fabricating large single-photon detector arrays combining high efficiency, low jitter, and low dark counts.",
        "pdf_url": "https://arxiv.org/pdf/1910.07010",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
        "dim_a": "",
        "dim_b": "",
