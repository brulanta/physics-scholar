        }
    },
    {
        "doi": "10.1038/ncomms1028",
        "s2_id": "4201b2addc857f9268b989d1b3a2360384a6a1dc",
        "title": "On-chip CMOS-compatible all-optical integrator",
        "authors": "M. Ferrera, Yongwoo Park, L. Razzari et al.",
        "year": 2010,
        "venue": "Nature Communications",
        "citation_count": 355,
        "abstract": "One reason for using photonic devices is their speed—much faster than electronic circuits—but there are many challenges in integrating the two technologies. Ferrera et al. construct a CMOS-compatible monolithic optical waveform integrator, a key building block for photonic circuits.",
        "pdf_url": "https://www.nature.com/articles/ncomms1028.pdf",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1002/lpor.201200032"
        ],
        "directions": [],
