    {
        "doi": "10.23919/cleo.2019.8750682",
        "s2_id": "1140bbc81a2815aa5e28dd6a72b09e7dd13d2ff7",
        "title": "Microresonator frequency comb generation with simultaneous Kerr and electro-optic nonlinearities",
        "authors": "Mian Zhang, C. Reimer, Lingyan He et al.",
        "year": 2019,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 7,
        "abstract": "We experimentally investigate electro-optic (EO) modulation of a dispersion engineered lithium niobate microring resonator under a strong optical pump. We show that EO modulated Kerr comb spectrum is significantly broader than with either Kerr or EO nonlinearity alone. © 2019 The Author(s)",
