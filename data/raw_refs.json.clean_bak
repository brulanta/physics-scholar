        }
    },
    {
        "doi": "10.1364/cleo_si.2020.sth1o.2",
        "s2_id": "c6b584e95847f1a991f0923b8db5746279c6c598",
        "title": "Low-Repetition-Rate Integrated Electro-Optic Frequency Comb Sources",
        "authors": "A. Shams-Ansari, C. Reimer, N. Sinclair et al.",
        "year": 2020,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 2,
        "abstract": "We demonstrate a low-repetition-rate lithium niobate based electro-optic (EO) frequency comb operating with 3.481 GHz line spacing, by integrating a cavity-based EO comb source with traveling-wave phase-modulators on the same chip.",
