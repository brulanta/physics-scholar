            "DOI": "10.1109/jlt.2019.2892317"
        }
    },
    {
        "doi": "10.1049/el:20060166",
        "s2_id": "5e1857c20519fdf17e09bbbf9e3a564a17e71b60",
        "title": "Wideband (0.045-6.25 GHz) 40 km analogue fibre-optic link with ultra-high (>40 dB) all-photonic gain",
        "authors": "V. Urick, M. Rogge, F. Bucholtz et al.",
        "year": 2006,
        "venue": "",
        "citation_count": 30,
        "abstract": "A low-biased Mach-Zehnder modulator, optical amplification, and a high-power photodetector are employed to achieve all-photonic link gain as high as 44 dB over a transmission length of 40 km. The link has a 3 dB bandwidth of 6.25 GHz and a 20 dB noise figure.",
