        "citationCount": 25,
        "externalIds": {
            "DOI": "10.1364/oe.27.001786"
        }
    },
    {
        "doi": "10.1364/ol.43.003610",
        "s2_id": "3bf647030853f903bf4ba226198c11cba359e2a6",
        "title": "Compact and electro-optic tunable interleaver in lithium niobate thin film",
        "authors": "X. Li, Kai Xin Chen, L. Wang",
        "year": 2018,
        "venue": "Asia Communications and Photonics conference and Exhibition",
        "citation_count": 25,
        "abstract": "We propose and experimentally demonstrate a compact and electro-optic tunable interleaver in lithium niobate thin film. The device exhibits polarization-insensitive center wavelengths and similar electrical wavelength-tuning sensitivity for TE and TM polarized input light, respectively.",
