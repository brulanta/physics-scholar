        "citationCount": 90,
        "externalIds": {
            "DOI": "10.1364/oe.19.023153"
        }
    },
    {
        "doi": "10.1364/oe.18.006156",
        "s2_id": "0745441c9551dccc528477bf52150e8c624a6a52",
        "title": "Wideband 360 degrees microwave photonic phase shifter based on slow light in semiconductor optical amplifiers.",
        "authors": "W. Xue, S. Sales, J. Capmany et al.",
        "year": 2010,
        "venue": "Optics Express",
        "citation_count": 90,
        "abstract": "In this work we demonstrate for the first time, to the best of our knowledge, a continuously tunable 360 degrees microwave phase shifter spanning a microwave bandwidth of several tens of GHz (up to 40 GHz). The proposed device exploits the phenomenon of coherent population oscillations, enhanced by optical filtering, in combination with a regeneration stage realized by four-wave mixing effects. This combination provides scalability: three hybrid stages are demonstrated but the technology allows an all-integrated device. The microwave operation frequency limitations of the suggested technique, dictated by the underlying physics, are also analyzed.",
        "pdf_url": "https://doi.org/10.1364/oe.18.006156",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1002/lpor.201200032"
        ],
        "directions": [],
        "dim_a": "",
