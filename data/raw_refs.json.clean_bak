    {
        "doi": "10.1364/ol.10.000417",
        "s2_id": "0d480df64c63119964326e43924aaebb99833d0b",
        "title": "Circuit effect in LiNbO(3) channel-waveguide modulators.",
        "authors": "R. A. Becker",
        "year": 1985,
        "venue": "Optics Letters",
        "citation_count": 45,
        "abstract": "An RC circuit is used to model transient effects that occur when dc or quasi-dc voltages are applied to channel waveguide modulators. These effects are believed to be due to the anisotropic redistribution over time of charge stored in the LiNbO(3). The anisotropy arises from the anisotropic material properties and the inhomogeneity induced when channel waveguides are formed. The transient effects measured are not caused by photorefractivity.",
        "pdf_url": "",
        "pub_types": [
            "JournalArticle"
        ],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
        "directions": [],
