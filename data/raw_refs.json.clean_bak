        "paperId": "a5f37f92ad6a5ed139000b7b7adc9156039b9cc0",
        "citationCount": 15,
        "externalIds": {
            "DOI": "10.1109/lpt.2010.2069558"
        }
    },
    {
        "doi": "10.1109/ecoc.2017.8346144",
        "s2_id": "cdb62fe6c604e0578d214ec459835f153892c8b6",
        "title": "Low Loss and Low Vpi Thin Film Lithium Niobate on Quartz Electro-optic Modulators",
        "authors": "V. Stenger, J. Toney, A. Pollick et al.",
        "year": 2017,
        "venue": "European Conference on Optical Communication",
        "citation_count": 15,
        "abstract": "Thin film lithium niobate (TFLN™) electro-optic modulators have potential for superior gain, bandwidth, linearity and impedance matching relative to semiconductor technologies. This paper reports TFLN modulators with optical loss < 0.5 dB/cm, Vpi-length of 2.2 V-cm, and 67 GHz operation.",
        "pdf_url": "",
        "pub_types": [
            "JournalArticle",
            "Conference"
        ],
        "source_reviews": [
