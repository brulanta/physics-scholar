        "s2_id": "6acd06870a5825a4e54b9b71e4662c8773db617b",
        "title": "An integrated broadband spectrometer on thin-film lithium niobate",
        "authors": "David Pohl, Marc Reig Escalé, M. Madi et al.",
        "year": 2019,
        "venue": "Nature Photonics",
        "citation_count": 188,
        "abstract": "",
        "pdf_url": "https://www.nature.com/articles/s41566-019-0529-9.pdf",
        "pub_types": [],
