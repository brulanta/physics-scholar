        }
    },
    {
        "doi": "10.1364/cleo_si.2013.cw3o.3",
        "s2_id": "db2fe9f58eed038be826a90405cb998c5c704c39",
        "title": "Engineered thin film lithium niobate substrate for high gain-bandwidth electro-optic modulators",
        "authors": "V. Stenger, J. Toney, A. Pollick et al.",
        "year": 2013,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 9,
        "abstract": "This paper reports the demonstration of a high-speed electro-optic modulator in crystal ion sliced thin film lithium niobate (TFLN™). Experimental results indicate potential to realize a 100 GHz TFLN™ modulator at 1550 nm with Vπ = 2.5V.",
        "pdf_url": "",
