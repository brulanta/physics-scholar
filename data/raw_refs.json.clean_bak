    {
        "doi": "10.1038/nphoton.2011.290",
        "s2_id": "61f6a36600f8fb5ca3dbafea5004615089646873",
        "title": "Microwave photonics: Harnessing slow light",
        "authors": "J. Capmany, I. Gasulla, S. Sales",
        "year": 2011,
