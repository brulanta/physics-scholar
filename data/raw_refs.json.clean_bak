        "citationCount": 163,
        "externalIds": {
            "DOI": "10.1364/ol.40.005117"
        }
    },
    {
        "doi": "",
        "s2_id": "68a769725fcb19439ffffe721c6063af22d7d22c",
        "title": "Open Foundry Platform for High-performance Electronic-photonic Integration References and Links",
        "authors": "J. Orcutt, B. Moss, Chen Sun et al.",
        "year": null,
        "venue": "",
        "citation_count": 162,
        "abstract": "",
        "pdf_url": "",
        "pub_types": [],
