        "citationCount": 42,
        "externalIds": {
            "DOI": "10.1063/1.5143266"
        }
    },
    {
        "doi": "10.1364/ol.44.004698",
        "s2_id": "0db433e6a179f53c31ff45a3ae37064a450fbb23",
        "title": "Fabrication of a multifunctional photonic integrated chip on lithium niobate on insulator using femtosecond laser-assisted chemomechanical polish.",
        "authors": "Rongbo Wu, Jintian Lin, Min Wang et al.",
        "year": 2019,
        "venue": "Optics Letters",
        "citation_count": 42,
        "abstract": "We report fabrication of a multifunctional photonic integrated chip on lithium niobate on insulator, which is achieved by femtosecond laser-assisted chemomechanical polish. We demonstrate a high-extinction-ratio beam splitter, a 1×6 optical switch, and a balanced 3×3 interferometer on the fabricated chip by reconfiguring the microelectrode array integrated with the multifunctional photonic circuit.",
        "pdf_url": "https://arxiv.org/pdf/1908.01856",
        "pub_types": [
            "JournalArticle"
