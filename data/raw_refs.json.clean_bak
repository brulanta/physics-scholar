    {
        "doi": "10.1109/lpt.2012.2196764",
        "s2_id": "2871df5ccc11c29cd2e184f4b4fdb19818c0f697",
        "title": "RF/Photonic Link-on-Chip PIC",
        "authors": "S. Jin, A. Bhardwaj, P. Herczfeld et al.",
        "year": 2012,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 7,
        "abstract": "We present the design and the first experimental results from a new device where an entire RF/photonic link is fabricated as a monolithic photonic integrated circuit (PIC). This novel “link-on-chip” PIC can operate in a linear mode or a mixer mode, depending on its intended application.",
