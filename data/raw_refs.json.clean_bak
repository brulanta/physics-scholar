        "paperId": "bc13fc785335e976c6a83e32210e64710b85b846",
        "citationCount": 18,
        "externalIds": {
            "DOI": "10.1364/oe.24.008797"
        }
    },
    {
        "doi": "10.1364/ome.4.000338",
        "s2_id": "01c4ab72caffd471f664ebf2b0006a162440181d",
        "title": "Micro-Raman spectroscopic visualization of lattice vibrations and strain in He + - implanted single-crystal LiNbO 3",
        "authors": "Hsu-Cheng Huang, J. Dadap, I. Herman et al.",
        "year": 2014,
        "venue": "",
        "citation_count": 17,
        "abstract": "Scanning micro-Raman spectroscopy has been utilized to image and investigate strain in He+-implanted congruent LiNbO3 samples. By using abruptly patterned implanted samples, we show that the spatial two-dimensional mapping of the Raman spectral peaks can be used to image the strain distribution and determine its absolute magnitude. We demonstrate that both short- and long-range length-scale in-plane and out-of-plane strain and stress states can be determined using the secular equations of phonon-deformation-potential theory. We also show that two-dimensional Raman imaging can be used to visualize the relaxation of strain in the crystal during low-temperature annealing.",
        "pdf_url": "https://doi.org/10.1364/ome.4.000338",
        "pub_types": [],
        "source_reviews": [
            "10.1364/AOP.411024"
        ],
