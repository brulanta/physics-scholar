        }
    },
    {
        "doi": "10.1109/lpt.2007.893023",
        "s2_id": "68a760bffbd525d2579df01525bdb1075d169191",
        "title": "Sub-10-dB Noise Figure in a Multiple-GHz Analog Optical Link",
        "authors": "J. McKinney, M. Godinez, V. Urick et al.",
        "year": 2007,
        "venue": "IEEE Photonics Technology Letters",
        "citation_count": 42,
        "abstract": "We present the first microwave analog optical link to achieve a noise figure (NF) below 10 dB. A link gain of up to ~6dB and common-mode noise rejection achieved via a dual-output Mach-Zehnder intensity modulator and differential detection enable us to achieve link NFs as low as ~7.5 dB in the range of ~2-6.5 GHz",
        "pdf_url": "",
        "pub_types": [],
