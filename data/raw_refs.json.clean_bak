        "citationCount": 44,
        "externalIds": {
            "DOI": "10.1364/oe.22.027733"
        }
    },
    {
        "doi": "10.1364/ol.22.000277",
        "s2_id": "ce67685ad14abb6104897436362ef00b68e72691",
        "title": "Large nonlinear phase shift owing to cascaded χ (2) in quasi-phase-matched bulk LiNbO 3",
        "authors": "P. Vidakovic, D. J. Lovering, J. Levenson et al.",
        "year": 1997,
        "venue": "",
        "citation_count": 44,
        "abstract": "Large nonresonant effective nonlinear indices that are due to cascading have been observed by Z-scan and CCD camera measurements performed on quasi-phase-matched LiNbO(3). Positive and negative values of n(cascad)(2) were measured at temperatures symmetrically displayed with respect to the optimum phase-matching temperatures (2.39 x 10(-13) and -2.37 x 10(-13)cm(2)/W, respectively).",
        "pdf_url": "",
