    {
        "doi": "10.1038/nphoton.2011.255",
        "s2_id": "029ae2ce04acd7dd226311d01c97c5705f068bc9",
        "title": "Spectral line-by-line pulse shaping of an on-chip microresonator frequency comb",
        "authors": "F. Ferdous, H. Miao, H. Miao et al.",
        "year": 2011,
        "venue": "Conference on Lasers and Electro-Optics",
        "citation_count": 451,
        "abstract": "We report spectral phase characterization and optical arbitrary waveform generation of on-chip microresonator combs. Random relative frequency shifts due to uncorrelated variations of frequency dependent phase are at or below the 100 μHz level.",
        "pdf_url": "http://arxiv.org/pdf/1103.2330",
